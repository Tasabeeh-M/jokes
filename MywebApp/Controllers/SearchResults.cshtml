@model IEnumerable<MywebApp.Models.Jokes>

@{
    ViewData["Title"] = "Search Results";
}

<div class="container mt-4">
    <h2 class="mb-3 text-primary">Search Results</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            No jokes found matching your search term.
        </div>
        <a asp-controller="Jokes" asp-action="ShowSearchForm" class="btn btn-outline-secondary">
            Try another search
        </a>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Question</th>
                    <th>Answer</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var joke in Model)
                {
                    <tr>
                        <td>@joke.JokesQuestion</td>
                        <td>@joke.JokesAnswer</td>
                        <td>
                            <a asp-controller="Jokes" asp-action="Details" asp-route-id="@joke.Id"
                               class="btn btn-sm btn-info">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3">
            <a asp-controller="Jokes" asp-action="Index" class="btn btn-outline-secondary">
                Back to Jokes List
            </a>
        </div>
    }
</div>